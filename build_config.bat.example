@echo off
REM ========================================================================
REM build_config.bat - Local build paths for build_portable.bat
REM ========================================================================
REM
REM Copy this file to build_config.bat and adjust the paths below to match
REM your local Qt / MinGW installation.
REM
REM build_config.bat is gitignored and will not be committed.
REM ========================================================================

set QT_PREFIX=C:\Qt\6.10.1\mingw_64
set MINGW_BIN=C:\Qt\Tools\mingw1310_64\bin
set CMAKE=C:\Qt\Tools\CMake_64\bin\cmake.exe
set NINJA=C:\Qt\Tools\Ninja\ninja.exe
set VNM_TERMINAL_SURFACE_SOURCE_DIR=C:\plms\varinomics\vnm_terminal_surface
set VNM_QML_CHROME_SOURCE_DIR=C:\plms\varinomics\vnm_qml_chrome
